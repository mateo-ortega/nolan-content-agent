# =============================================================================
# Nolan — .env.example
# =============================================================================
# Copiar a .env (NUNCA commit). En VPS: chmod 600 .env
# Fuentes: OpenRouter, Perplexity, Apify, Pexels/Pixabay, Telegram BotFather,
#          Google Drive service account, ElevenLabs (opcional).
# =============================================================================

# ---- LLM gateway (OpenRouter, una sola key) --------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://sapienseducation.com
OPENROUTER_X_TITLE=nolan

# Slugs (se leen en config/llm_routing.yaml — mantener sincronizado)
OPENROUTER_MODEL_COPY=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_RESEARCH=deepseek/deepseek-chat

# ---- Research APIs (directas, fuera de OpenRouter) -------------------------
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PERPLEXITY_MODEL=sonar-pro

APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# B-roll (opcional, para reels voiceover)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Voz sintética (opcional, v1 off)
ELEVENLABS_API_KEY=

# ---- Gateway Telegram vía Hermes -------------------------------------------
# Crear con @BotFather; nombre sugerido: "Nolan | Sapiens Bot"
HERMES_TELEGRAM_BOT_TOKEN=
# IDs numéricos de Mateo (obtener con @userinfobot). Separados por coma si varios.
TELEGRAM_ALLOWED_USERS=
# Fallback global (Hermes lee ambos):
GATEWAY_ALLOWED_USERS=

# WhatsApp (v1 off — reservar para fase 6)
HERMES_WHATSAPP_PROVIDER=

# ---- Google Drive via rclone ------------------------------------------------
# rclone corre en host (no dentro del contenedor Hermes)
RCLONE_REMOTE=gdrive_sapiens
DRIVE_ROOT=SapiensContent

# ---- Budget guard -----------------------------------------------------------
LLM_MONTHLY_BUDGET_USD=50
BUDGET_WARN_THRESHOLD=0.70
BUDGET_KILL_THRESHOLD=0.90

# ---- Infraestructura --------------------------------------------------------
TZ=America/Bogota
HERMES_HOME=/home/nolan/.hermes
SAPIENS_LOGO_PATH=/srv/sapiens-nolan/assets/sapiens_logo_wm.png

# ---- Plugin de memoria externa (decisión en fase 3) ------------------------
# Opciones evaluadas: mem0, honcho, openviking, hindsight
HERMES_MEMORY_PLUGIN=
MEM0_API_KEY=
HONCHO_API_KEY=

# ---- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
